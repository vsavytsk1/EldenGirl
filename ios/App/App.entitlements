<?xml version="1.0" encoding="UTF-8"?>
<!--
    G1/G8 (iOS form): keychain access only, and NOTHING else. No app groups (they
    share a container off-device paths can reach), no iCloud, no push, no
    associated domains. Any entitlement beyond keychain access fails the gate.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    </array>
</dict>
</plist>
