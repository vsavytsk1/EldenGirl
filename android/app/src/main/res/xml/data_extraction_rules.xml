<?xml version="1.0" encoding="utf-8"?>
<!--
    G7 · BACKUP AND DEVICE-TRANSFER EXCLUSION (S4, v1.5 Part III·5).
    API 31 split these into two paths. BOTH must exclude every domain, because a
    "new phone" migration is a backup wearing a different name — and setting up her
    new phone is exactly the moment a controlling partner offers to "help".

    ⚠️ Android backup semantics move. Re-verify against current documentation
    before trusting this file (v1.3's own warning applies to every version).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
